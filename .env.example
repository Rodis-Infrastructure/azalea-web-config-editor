# Path to the Azalea bot's working tree. Both `configs/` (read/write) and
# the parent directory's `ecosystem.config.js` (for `pm2 reload`) are
# resolved relative to this.
AZALEA_REPO_PATH="/Users/nick/Developer/azalea"

# Name of the bot's PM2 application. The save pipeline runs
# `pm2 reload <name> --update-env` on a successful write.
AZALEA_PM2_APP_NAME="azalea"

# URL of the bot's health endpoint. The editor polls this after each
# `pm2 reload` to verify the new process came up cleanly.
AZALEA_HEALTH_URL="http://127.0.0.1:7475/healthz"

# Discord OAuth application credentials. Configure a new application at
# https://discord.com/developers/applications with redirect URI matching
# DISCORD_OAUTH_REDIRECT_URI below.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_OAUTH_REDIRECT_URI="https://editor.example.com/auth/callback"

# Bot token (read-only re-use of the bot's own token). Used to enumerate
# channels, roles, and emojis, and to fetch members for permission checks.
DISCORD_TOKEN=""

# 32+ random bytes; used to sign session cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=""

# Editor binding. Defaults to 127.0.0.1:7476. Always front with a reverse
# proxy that terminates TLS — never expose this directly.
EDITOR_HOST="127.0.0.1"
EDITOR_PORT="7476"

# Comma-separated Discord user IDs that bypass the per-guild
# `manage_guild_config` permission check. Use this to bootstrap the first
# admin in a fresh guild config; remove once a role has been granted the
# permission.
BOOTSTRAP_USER_IDS=""
