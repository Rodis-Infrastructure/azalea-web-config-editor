node_modules/
*.tsbuildinfo
.env
.env.*
!.env.example

# Defeat the "lib/" entry that some global ~/.gitignore_global files
# carry (intended for Python venvs / Node build output). The editor
# uses src/lib/ and ui/src/lib/ as source directories — they MUST ship.
!src/lib/
!ui/src/lib/

# Vite build output
ui/dist/

# Editor-local state — sessions, audit log, lock files
data/editor.db
data/editor.db-journal
data/editor.db-shm
data/editor.db-wal
data/locks/

.DS_Store
.idea/
.vscode/
